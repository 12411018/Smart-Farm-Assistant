# Smart Farming Assistant - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ============================================
# DATABASE CONFIGURATION (REQUIRED)
# ============================================
# PostgreSQL connection string
# Format: postgresql+psycopg2://username:password@host:port/database

# For local development - UPDATE THE PASSWORD:
DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@localhost:5432/smart_irrigation

# Examples:
# DATABASE_URL=postgresql+psycopg2://postgres:Parth%402006@localhost:5432/smart_irrigation
# DATABASE_URL=postgresql+psycopg2://postgres:NIKKKHIL001@localhost:5432/smart_irrigation

# ============================================
# WEATHER API (REQUIRED)
# ============================================
# OpenWeather API Key - Get from: https://openweathermap.org/api
OPENWEATHER_API_KEY=1c7044d8c4b9927ec447648fe457e723

# ============================================
# OLLAMA CONFIGURATION (OPTIONAL)
# ============================================
# Ollama endpoint for local LLM
OLLAMA_ENDPOINT=http://localhost:11434/api/generate
OLLAMA_MODEL=mistral:latest

# Fallback model if primary model fails
OLLAMA_FALLBACK_MODEL=phi3:mini

# Model parameters (optional tuning)
OLLAMA_NUM_PREDICT=96
OLLAMA_TEMPERATURE=0.35
OLLAMA_TOP_P=0.9
OLLAMA_NUM_CTX=1024

# ============================================
# FIREBASE CONFIGURATION (OPTIONAL)
# ============================================
# Option 1: Using Project ID (Simplest)
FIREBASE_PROJECT_ID=smart-irrigation-system-f87ad

# Option 2: Using Service Account Key (More Secure)
# FIREBASE_SERVICE_ACCOUNT_KEY=backend/serviceAccountKey.json

# ============================================
# MERGE COMPATIBILITY NOTES
# ============================================
# This .env file helps avoid conflicts when merging with:
# https://github.com/12411018/Smart-Farm-Assistant.git
#
# Different team members may use different passwords:
# - GitHub default: NIKKKHIL001
# - Local dev: Parth@2006
# 
# Using .env ensures everyone can work with their own credentials
# without hardcoding them in database.py
